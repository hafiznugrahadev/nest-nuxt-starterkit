# Port dev server web (Nuxt). Ganti bebas kalau bentrok dengan app lain.
PORT=4300
# Host bind (default localhost). Pakai 0.0.0.0 kalau mau diakses dari device lain.
HOST=localhost

# Public — di-expose ke client via useRuntimeConfig().public
# Samakan port-nya dengan PORT di apps/api/.env
NUXT_PUBLIC_API_BASE=http://localhost:4400/api
