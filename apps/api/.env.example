# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
# Port API — ganti bebas kalau bentrok dengan app lain.
PORT=4400
API_PREFIX=api
# Asal request yang diizinkan (port web). Pisahkan dengan koma untuk banyak origin.
CORS_ORIGIN=http://localhost:4300

# ── Database (Prisma / PostgreSQL) ───────────────────────────────────────────
DATABASE_URL=postgresql://minisoccer:minisoccer@localhost:5432/minisoccer?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars-long
# Umur access token (pendek). Refresh token (httpOnly cookie) berumur panjang.
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
