// Prisma schema for starterkit. UserRole mirrors @starterkit/shared-types.
// Prisma 7: Rust-free `prisma-client` generator + a driver adapter at runtime
// (see prisma.service.ts). The client is generated into src/ so nest build emits it.
generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URL lives in prisma.config.ts (Migrate) and the
  // driver adapter (runtime). It is no longer set here.
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String
  password      String
  role          UserRole       @default(USER)
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  familyId  String // tokens rotated from one login share a family (reuse detection)
  tokenHash String    @unique // SHA-256 of the opaque token (raw value never stored)
  revokedAt DateTime? // set on rotation/logout; a non-null value means unusable
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}
