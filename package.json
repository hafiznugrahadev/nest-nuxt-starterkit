{
  "name": "starterkit",
  "version": "0.1.0",
  "private": true,
  "description": "Starter Kit — NestJS API + Nuxt 4 web monorepo (Bun + Turbo)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "init": "bun run scripts/init-project.ts",
    "dev": "turbo run dev",
    "serve": "turbo run dev",
    "serve:api": "turbo run dev --filter=@starterkit/api",
    "serve:web": "turbo run dev --filter=@starterkit/web",
    "build": "turbo run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "turbo run test",
    "db:restore": "cd apps/api && bun run scripts/db-restore.ts",
    "db:restore:docker": "docker compose run --rm db-tools",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,vue,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "3.8.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.20.0",
    "vue-eslint-parser": "^9.4.3"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": "prettier --write"
  },
  "packageManager": "bun@1.3.3",
  "engines": {
    "bun": ">=1.3.0"
  }
}
