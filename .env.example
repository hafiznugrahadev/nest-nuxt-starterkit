# ╭──────────────────────────────────────────────────────────────────────────╮
# │ starterkit — SINGLE root .env for the whole monorepo                         │
# │   • docker-compose (infra + apps) reads it for variable substitution         │
# │   • apps/api  (NestJS) loads it via ConfigModule envFilePath: ../../.env      │
# │   • apps/web  (Nuxt)   loads it via `nuxt --dotenv ../../.env`                │
# │ There are no per-app .env files — keep everything here.                       │
# ╰──────────────────────────────────────────────────────────────────────────╯
#
# Networking (compose): attach to the shared `dokploy-network`.
# Create it once on the host:  docker network create dokploy-network

# ── App ports (change freely if they clash with your other apps) ───────────────
WEB_PORT=4300
API_PORT=4400

# ── API runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PREFIX=api
# Allowed web origin(s) for CORS (comma-separated). Required for the auth cookie —
# a wildcard "*" is rejected by browsers for credentialed requests.
CORS_ORIGIN=http://localhost:4300
LOG_LEVEL=debug

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
POSTGRES_USER=starterkit
POSTGRES_PASSWORD=starterkit
POSTGRES_DB=starterkit
POSTGRES_PORT=5432
# Connection string used by Prisma (local dev → host-mapped Postgres).
DATABASE_URL=postgresql://starterkit:starterkit@localhost:5432/starterkit?schema=public

# ── Redis ───────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Auth (JWT) ──────────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-me-min-16-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# Self-service registration. Off by default (the kit is admin-provisioned). When
# you enable it, keep the API flag (AUTH_REGISTRATION_ENABLED) and the web flag
# (NUXT_PUBLIC_REGISTRATION_ENABLED) in sync. The docker-compose dev stack drives
# both from a single REGISTRATION_ENABLED var (defaults to true for dev).
# AUTH_REGISTRATION_ENABLED=false
# NUXT_PUBLIC_REGISTRATION_ENABLED=false
# REGISTRATION_ENABLED=true   # docker-compose only: sets both of the above

# ── Swagger docs (Basic Auth protected — change creds in prod, or disable) ───────
SWAGGER_ENABLED=true
SWAGGER_USER=admin
SWAGGER_PASSWORD=admin

# ── Rate limiting (global) ──────────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
# Skip ALL rate limiting (incl. per-route @Throttle) — handy for E2E/load tests.
# The docker-compose dev stack enables this for the api container by default.
# THROTTLE_DISABLED=false

# ── File storage (uploads) ──────────────────────────────────────────────────────
# Driver: "local" (default, zero-infra → writes to apps/api/storage/uploads and is
# served at /uploads) or "s3" (AWS S3 / MinIO / RustFS).
STORAGE_DRIVER=local
STORAGE_MAX_FILE_SIZE_MB=5
# STORAGE_LOCAL_DIR=./storage/uploads
# STORAGE_PUBLIC_BASE_URL=http://localhost:4400
# STORAGE_ALLOWED_MIME=image/jpeg,image/png,image/webp,image/gif,application/pdf
#
# S3 / MinIO — only used when STORAGE_DRIVER=s3:
# S3_ENDPOINT=http://localhost:9000      # MinIO endpoint; omit for real AWS S3
# S3_REGION=us-east-1
# S3_BUCKET=starterkit
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_FORCE_PATH_STYLE=true               # required by MinIO
# S3_PUBLIC_BASE_URL=                    # optional CDN/public base fronting the bucket

# ── Mail ────────────────────────────────────────────────────────────────────────
# Transport: "log" (default — emails written to the API logs, zero-infra) or "smtp".
# NOTE: the docker-compose dev stack overrides this to smtp → the Mailpit container
# (web UI at http://localhost:8025). These values apply to non-docker/local runs.
MAIL_TRANSPORT=log
MAIL_FROM=Starter Kit <no-reply@starterkit.test>
# SMTP — only used when MAIL_TRANSPORT=smtp (e.g. point at Mailpit on localhost:1025):
# MAIL_SMTP_HOST=localhost
# MAIL_SMTP_PORT=1025
# MAIL_SMTP_SECURE=false
# MAIL_SMTP_USER=
# MAIL_SMTP_PASSWORD=
# Mailpit host-published ports (docker-compose dev):
# MAILPIT_SMTP_PORT=1025
# MAILPIT_UI_PORT=8025

# ── Password reset ──────────────────────────────────────────────────────────────
PASSWORD_RESET_TTL_MIN=30
# Frontend page the emailed reset link points to (token appended as ?token=).
PASSWORD_RESET_URL=http://localhost:4300/reset-password

# ── Web (Nuxt) — public, exposed to the browser ─────────────────────────────────
NUXT_PUBLIC_API_BASE=http://localhost:4400/api

# ╭──────────────────────────────────────────────────────────────────────────╮
# │ PROD (docker-compose.prod.yml) — set these in the Dokploy UI. Postgres/Redis │
# │ are provisioned by Dokploy, so point DATABASE_URL / REDIS_HOST at those.      │
# ╰──────────────────────────────────────────────────────────────────────────╯
# DATABASE_URL=postgresql://USER:PASS@starterkit-db:5432/starterkit?schema=public
# REDIS_HOST=starterkit-redis
# CORS_ORIGIN=https://app.example.com
# NUXT_PUBLIC_API_BASE=https://api.example.com/api
