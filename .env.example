# ╭──────────────────────────────────────────────────────────────────────────╮
# │ minisoccer — root .env (consumed by docker-compose: dev infra + apps)        │
# ╰──────────────────────────────────────────────────────────────────────────╯
#
# Port overview (change any freely if it clashes with your other apps):
#
#   ┌─────────────┬─────────┬──────────────────────────────────────────────┐
#   │ Web (Nuxt)  │  4300   │ WEB_PORT (here) + apps/web/.env → PORT        │
#   │ API (Nest)  │  4400   │ API_PORT (here) + apps/api/.env → PORT        │
#   │ PostgreSQL  │  5432   │ POSTGRES_PORT                                │
#   │ Redis       │  6379   │ REDIS_PORT                                   │
#   │ RustFS (S3) │  9000   │ RUSTFS_PORT                                  │
#   └─────────────┴─────────┴──────────────────────────────────────────────┘
#
# Networking: dev & prod compose attach to the shared `dokploy-network`.
# Create it once on the host:  docker network create dokploy-network

# ── App ports ─────────────────────────────────────────────────────────────────
WEB_PORT=4300
API_PORT=4400

# ── Infra: PostgreSQL (dev compose) ──────────────────────────────────────────
POSTGRES_USER=minisoccer
POSTGRES_PASSWORD=minisoccer
POSTGRES_DB=minisoccer
POSTGRES_PORT=5432

# ── Infra: Redis (dev compose) ───────────────────────────────────────────────
REDIS_PORT=6379

# ── Infra: RustFS — S3-compatible object storage (dev compose) ───────────────
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_PORT=9000

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-me-min-16-chars

# ╭──────────────────────────────────────────────────────────────────────────╮
# │ PROD only (docker-compose.prod.yml) — set these in the Dokploy UI instead.  │
# │ Postgres/Redis are provisioned by Dokploy, so point these at those.         │
# ╰──────────────────────────────────────────────────────────────────────────╯
# DATABASE_URL=postgresql://USER:PASS@minisoccer-db:5432/minisoccer?schema=public
# REDIS_HOST=minisoccer-redis
# REDIS_PASSWORD=
# CORS_ORIGIN=https://app.example.com
# NUXT_PUBLIC_API_BASE=https://api.example.com/api
